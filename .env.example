# Server
HOST=0.0.0.0
PORT=8000
ENVIRONMENT=development
DEBUG=true

# App
APP_NAME="Production AI Agent"
APP_VERSION="1.0.0"

# LLM Config (Mock LLM bypasses this)
OPENAI_API_KEY=""
LLM_MODEL=gpt-4o-mini

# Security
AGENT_API_KEY="dev-key-change-me"
JWT_SECRET="dev-jwt-secret"
ALLOWED_ORIGINS="*"

# Rate Limiting
RATE_LIMIT_PER_MINUTE=10

# Budget Guard
DAILY_BUDGET_USD=10.0

# Storage (Leave empty for in-memory fallback during local testing)
REDIS_URL=""
